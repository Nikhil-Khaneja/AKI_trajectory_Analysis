# Snowflake credentials
SF_USER=your_snowflake_user
SF_PASSWORD=your_snowflake_password
SF_ACCOUNT=your_account.snowflakecomputing.com
SF_WAREHOUSE=your_warehouse
SF_ROLE=SYSADMIN

# Stage configuration
# 'local' = PUT local CSV files to internal stage
# 's3'    = use pre-configured external S3 stage
SF_STAGE_MODE=local
SF_STAGE=@AKI_DB.BRONZE.AKI_STAGE

# MIMIC-IV data directory (local mode only)
MIMIC_DATA_DIR=/path/to/mimic-iv/csv/files
